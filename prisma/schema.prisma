generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model WaitlistEntry {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique
  firstName       String?   @db.VarChar(100)
  userAgent       String?
  status          Status    @default(SUBSCRIBED)
  signupSource    String?   @default("organic")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastContactedAt DateTime?

  @@index([email])
  @@index([status])
  @@index([signupSource])
}

model BroadcastLog {
  id             String   @id @default(uuid()) @db.Uuid
  title          String
  sentAt         DateTime @default(now())
  recipientCount Int
  senderId       String
  content        String
  failureCount   Int      @default(0)
  successCount   Int      @default(0)
}

enum Status {
  SUBSCRIBED
  UNSUBSCRIBED
  INVITED
  JOINED
  BOUNCED
}
